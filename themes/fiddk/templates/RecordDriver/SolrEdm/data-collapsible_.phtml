<?php
$lang = $this->plugin('translate')->getTranslator()->getLocale();

$data  = is_array($data) ? $data : [];
$first = array_slice($data, 0, 5);
$rest  = array_slice($data, 5);
?>

<?php foreach ($first as $link => $field): ?>
    <a href="<?= $this->escapeHtmlAttr($link) ?>" target="_blank">
        <?= $this->escapeHtml($field) ?>
    </a><br/>
<?php endforeach; ?>

<?php if (!empty($rest)): ?>
    <span class="toggleContainer">
        <input type="checkbox" class="toggle" id="toggle_subject">

        <span class="toggleContent">
            <?php foreach ($rest as $link => $field): ?>
                <a href="<?= $this->escapeHtmlAttr($link) ?>" target="_blank">
                    <?= $this->escapeHtml($field) ?>
                </a><br/>
            <?php endforeach; ?>
        </span>

        <label for="toggle_subject"
               class="<?= $lang === 'de' ? 'label_de' : 'label_en' ?>">
        </label>
    </span>
    <br/>
<?php endif; ?>

